# .gitignore for octiv-mcp

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# uv
# uv.lock is intentionally committed — do not ignore it

# Pytest
.pytest_cache/

# Ruff
.ruff_cache/

# Type checkers
.mypy_cache/
.ty_cache/

# Environment / secrets
.env
.env.*
!.env.example

# Auth token cache written by the server at runtime
# (~/.octiv_mcp/ lives outside the repo)

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
